---
import logoDark from "../assets/logo-dark.svg?url";
import "../styles/landing.css";

const issues = [
  {
    title: "Add visual proof for the onboarding dashboard",
    number: 42,
    labels: ["feature", "agent-ready", "plan-approved", "priority:high"],
    meta: "opened by patchmill-demo · ready for run-once",
  },
  {
    title: "Document repo-local Pi auth repair flow",
    number: 39,
    labels: ["docs", "spec-approved", "plan-review"],
    meta: "opened by docs-lead · waiting for plan review",
  },
  {
    title: "Triage flaky setup-test-repo bootstrap",
    number: 37,
    labels: ["bug", "in-progress", "blocked"],
    meta: "opened by qa-bot · blocked on provider access",
  },
  {
    title: "Shape provider onboarding around team policy",
    number: 34,
    labels: ["enhancement", "needs-info", "spec-review", "priority:medium"],
    meta: "opened by platform-team · needs human decision",
  },
];

const labelClass = (label: string) =>
  `label label-${label.replace(/[^a-z0-9]+/gi, "_")}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Patchmill — agent-driven software factory</title>
    <meta
      name="description"
      content="Patchmill is an agent-driven software factory for your engineering process."
    />
  </head>
  <body>
    <main class="page-shell">
      <section class="intro" aria-labelledby="hero-heading">
        <div class="hero-lockup">
          <a class="brand" href="/" aria-label="Patchmill home">
            <img src={logoDark} alt="Patchmill" />
          </a>
          <div class="hero-copy">
            <h1 id="hero-heading">An AI Software Factory With You In The Loop</h1>
            <nav class="top-nav" aria-label="Primary navigation">
              <a href="/getting-started/quickstart/">
                <span>Get started</span>
                <svg aria-hidden="true" viewBox="0 0 16 16">
                  <path d="M8.22 3.22a.75.75 0 0 1 1.06 0l4.25 4.25a.75.75 0 0 1 0 1.06l-4.25 4.25a.75.75 0 0 1-1.06-1.06L11.19 8.75H3a.75.75 0 0 1 0-1.5h8.19L8.22 4.28a.75.75 0 0 1 0-1.06Z" />
                </svg>
              </a>
              <a href="https://github.com/rochecompaan/patchmill">
                <span>View on GitHub</span>
                <svg aria-hidden="true" viewBox="0 0 16 16">
                  <path d="M4.75 3A1.75 1.75 0 0 0 3 4.75v6.5C3 12.216 3.784 13 4.75 13h6.5A1.75 1.75 0 0 0 13 11.25v-2a.75.75 0 0 0-1.5 0v2a.25.25 0 0 1-.25.25h-6.5a.25.25 0 0 1-.25-.25v-6.5a.25.25 0 0 1 .25-.25h2a.75.75 0 0 0 0-1.5h-2Z" />
                  <path d="M8.25 3a.75.75 0 0 0 0 1.5h2.19L7.72 7.22a.75.75 0 0 0 1.06 1.06l2.72-2.72v2.19a.75.75 0 0 0 1.5 0v-4A.75.75 0 0 0 12.25 3h-4Z" />
                </svg>
              </a>
            </nav>
          </div>
        </div>
      </section>

      <section class="proof-section" aria-label="Patchmill workflow proof">
        <div class="message-block">
          <ul class="feature-list">
            <li>Declare skills, labels, gates, providers, reviews, and evidence once.</li>
            <li>Run the same engineering process across issues without re-explaining it.</li>
            <li>Keep humans in control with observable labels, approvals, plans, and handoffs.</li>
            <li>Customize skills as your team changes how it plans, debugs, tests, and reviews.</li>
          </ul>
        </div>

        <aside class="issues-card" aria-label="GitHub issues mockup showing Patchmill workflow labels">
          <div class="github-window-bar">
            <div>
              <span class="repo-owner">patchmill-demo</span><span class="repo-separator">/</span><strong>team-lunch-poll</strong>
            </div>
            <span class="repo-visibility">Public</span>
          </div>
          <div class="github-tabs" aria-hidden="true">
            <span>Code</span>
            <strong>Issues <em>7</em></strong>
            <span>Pull requests</span>
            <span>Actions</span>
          </div>
          <div class="issues-toolbar">
            <strong>7 Open</strong>
            <span>2 Closed</span>
            <button type="button">New issue</button>
          </div>
          <div class="issue-list">
            {
              issues.map((issue) => (
                <article class="issue-row">
                  <div class="issue-icon" aria-hidden="true">
                    <svg viewBox="0 0 16 16" width="16" height="16">
                      <circle cx="8" cy="8" r="6" fill="none" stroke="currentColor" stroke-width="2" />
                      <circle cx="8" cy="8" r="2" fill="currentColor" />
                    </svg>
                  </div>
                  <div class="issue-body">
                    <h2>
                      {issue.title}
                      <span>#{issue.number}</span>
                    </h2>
                    <div class="labels" aria-label="Issue labels">
                      {issue.labels.map((label) => <span class={labelClass(label)}>{label}</span>)}
                    </div>
                    <p>{issue.meta}</p>
                  </div>
                </article>
              ))
            }
          </div>
        </aside>
      </section>
    </main>
  </body>
</html>
