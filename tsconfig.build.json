{
  "compilerOptions": {
    "target": "ES2024",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": ".",
    "allowImportingTsExtensions": true,
    "rewriteRelativeImportExtensions": true,
    "noCheck": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true
  },
  "include": ["bin/**/*.ts", "src/**/*.ts"],
  "exclude": ["**/*.test.ts", "dist", "node_modules"]
}
